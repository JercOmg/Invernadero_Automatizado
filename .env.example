# ============================================
# INVERNADERO AUTOMATIZADO - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como '.env' e introduce tus valores reales.
# El archivo '.env' esta excluido del control de versiones.

# --------------------------------------------
# Backend (Spring Boot)
# --------------------------------------------

# Credenciales de Base de Datos PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/invernadero_db
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui

# Seguridad JWT
# Genera una clave segura de 256 bits en Base64 (minimo 32 caracteres)
JWT_SECRET=CambiaEstaClavePorUnaMasSeguraEnProduccionDeAlMenos32Caracteres
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Google OAuth2 (Login)
# Obtenidos desde Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# --------------------------------------------
# Integracion Taiga (CI/CD)
# --------------------------------------------
TAIGA_API_URL=https://api.taiga.io/api/v1
TAIGA_AUTH_TOKEN=tu_taiga_application_token
TAIGA_PROJECT_ID=tu_taiga_project_id_numerico

# --------------------------------------------
# Despliegue CI/CD (GitHub Actions Secrets)
# --------------------------------------------
# RENDER_DEPLOY_HOOK_BACKEND=https://api.render.com/deploy/srv-...
# VERCEL_TOKEN=tu_vercel_token
# VERCEL_ORG_ID=tu_vercel_org_id
# VERCEL_PROJECT_ID=tu_vercel_project_id
